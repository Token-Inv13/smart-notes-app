NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id
NEXT_PUBLIC_FCM_VAPID_KEY=your_fcm_vapid_key
NEXT_PUBLIC_USE_EMULATORS=false

# App origin used by server-side Google Calendar OAuth routes when building the callback URL.
# Keep at least one of these aligned with the real app host.
NEXT_PUBLIC_APP_URL=https://app.tasknote.io
APP_BASE_URL=https://app.tasknote.io

# Google Calendar OAuth server config.
# GOOGLE_CLIENT_SECRET is optional with the current PKCE flow, but recommended for production parity.
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# Optional explicit callback URL. If omitted, the app builds:
#   {NEXT_PUBLIC_APP_URL or APP_BASE_URL}/api/google/calendar/callback
GOOGLE_CALENDAR_REDIRECT_URI=https://app.tasknote.io/api/google/calendar/callback

# Server-only secret used to encrypt Google Calendar OAuth tokens at rest.
# Keep this secret private (do NOT prefix with NEXT_PUBLIC_).
# If omitted, the app falls back to APP_SECRET.
GOOGLE_CALENDAR_TOKEN_ENCRYPTION_KEY=replace_with_a_long_random_secret
APP_SECRET=replace_with_a_long_random_secret

# SMTP (Functions: task reminder emails + ops alert emails)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=demande-service@tasknote.io
SMTP_PASS=replace_with_hostinger_smtp_password
SMTP_FROM=demande-service@tasknote.io
EMAIL_TEST_SECRET=replace_with_a_random_secret_for_email_test_routes

# PR-12 Ops monitoring/alerting (Functions)
OPS_ALERT_EMAIL_TO=
OPS_ALERT_COOLDOWN_MS=1800000
OPS_ALERT_BACKLOG_THRESHOLD_REMINDERS=180
OPS_ALERT_BACKLOG_THRESHOLD_ASSISTANT=40
OPS_ALERT_CONSEC_FAIL_THRESHOLD=3
OPS_ALERT_ERROR_RATE_THRESHOLD=0.3
OPS_ALERT_STALE_SUCCESS_MS=900000
OPS_ALERT_GOOGLE_GUARD_THRESHOLD=6
SLACK_WEBHOOK_URL=
